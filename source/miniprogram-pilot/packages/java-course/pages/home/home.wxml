<view class="jc-page {{__themeDark ? 'dark-theme' : ''}} secondary-shell" style="padding-top: {{navSafeTop}}px;">
  <view class="secondary-nav secondary-nav--back-only"><view class="secondary-nav__back" bindtap="goBack" data-secondary-route="packages/java-course/pages/home/home"><text class="secondary-nav__back-icon">‹</text></view></view>
  <block wx:if="{{loadError}}"><view class="jc-empty"><text class="jc-empty__title">Java 课程暂不可用</text><text class="jc-empty__sub">课程目录加载失败，请返回课程页后重试。</text><view class="jc-btn jc-btn--outline" bindtap="goBack">返回课程</view></view></block>
  <block wx:else><view class="jc-hero"><text class="jc-kicker">Java Course</text><text class="jc-title">{{manifest.title.ja}}</text><text class="jc-sub">{{manifest.title.zh}} · {{manifest.subtitle.ja}}</text><view class="jc-stats"><view class="jc-stat"><text class="jc-stat__num">{{manifest.totalChapters}}</text><text class="jc-stat__label">章节</text></view><view class="jc-stat"><text class="jc-stat__num">{{manifest.totalSections}}</text><text class="jc-stat__label">小节</text></view><view class="jc-stat"><text class="jc-stat__num">0</text><text class="jc-stat__label">选择式练习</text></view></view><view class="jc-btn jc-btn--primary" bindtap="startFirstLesson">从第一节开始</view></view><view class="jc-section"><text class="jc-section__title">章节目录</text><view class="jc-chapter" wx:for="{{chapters}}" wx:key="chapterId" bindtap="openChapter" data-route="{{item.chapterRoute}}"><view class="jc-chapter__body"><text class="jc-chapter__ja">{{item.title.ja}}</text><text class="jc-chapter__zh">{{item.title.zh}}</text><text class="jc-chapter__meta">{{item.sections.length}} 小节 · {{item.sourceChapter}}</text></view><text class="jc-chapter__arrow">→</text></view></view></block>
</view>
