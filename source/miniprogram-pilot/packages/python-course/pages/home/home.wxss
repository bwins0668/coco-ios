@import "../../../../styles/secondary-page-shell.wxss";
@import "../../../../styles/tokens.wxss";
page{background:#FBF7EF;overflow-x:hidden}.pc-page{--python-khaki-accent:#9A7B48;--python-khaki-strong:#765A2B;--python-khaki-soft:#F4EBD8;--python-khaki-border:#D8C39A;--python-khaki-ink:#4A3B25;min-height:100vh;padding:28rpx;box-sizing:border-box;background:#FBF7EF;color:var(--python-khaki-ink);overflow-x:hidden}.pc-page.dark-theme{background:var(--bg-color);color:var(--text-primary)}.pc-hero,.pc-section,.pc-empty{background:#FFFDF8;border:var(--qp-border-width) solid var(--python-khaki-border);border-radius:var(--qp-radius-sm)}.pc-hero{padding:28rpx;margin-bottom:24rpx;border-top:5rpx solid var(--python-khaki-accent)}.pc-kicker{display:block;color:var(--python-khaki-accent);font-size:22rpx;font-weight:700;margin-bottom:8rpx}.pc-title{display:block;color:var(--python-khaki-ink);font-size:42rpx;line-height:1.25;font-weight:700}.pc-sub,.pc-empty__sub,.pc-chapter__zh,.pc-chapter__meta{display:block;color:#6E6250;font-size:25rpx;line-height:1.6}.pc-stats{display:flex;gap:12rpx;margin:24rpx 0}.pc-stat{flex:1;padding:16rpx;border-radius:var(--qp-radius-tag);background:var(--python-khaki-soft);border:var(--qp-border-width) solid var(--python-khaki-border)}.pc-stat__num{display:block;color:var(--python-khaki-strong);font-size:34rpx;font-weight:700}.pc-stat__label{display:block;color:#6E6250;font-size:22rpx}.pc-btn{min-height:76rpx;display:flex;align-items:center;justify-content:center;border-radius:var(--qp-radius-tag);font-size:27rpx;font-weight:700}.pc-btn--primary{background:var(--python-khaki-accent);color:#FFFDF8}.pc-btn--outline{border:var(--qp-border-width) solid var(--python-khaki-border);color:var(--python-khaki-strong)}.pc-section{padding:20rpx;margin-bottom:20rpx}.pc-section__title{display:block;color:var(--python-khaki-strong);font-size:24rpx;font-weight:700;margin-bottom:14rpx}.pc-chapter{display:flex;gap:16rpx;align-items:center;padding:18rpx 0;border-top:var(--qp-border-width) solid var(--python-khaki-border)}.pc-chapter:first-of-type{border-top:0}.pc-chapter__body{flex:1;min-width:0}.pc-chapter__ja{display:block;color:var(--python-khaki-ink);font-size:29rpx;line-height:1.35;font-weight:700}.pc-chapter__arrow{flex:none;color:var(--python-khaki-accent);font-size:32rpx}.pc-empty{padding:44rpx 24rpx}.pc-empty__title{display:block;font-size:34rpx;font-weight:700;margin-bottom:8rpx}.pc-page.dark-theme .pc-hero,.pc-page.dark-theme .pc-section,.pc-page.dark-theme .pc-empty{background:var(--card-bg);border-color:var(--border-color)}.pc-page.dark-theme .pc-title,.pc-page.dark-theme .pc-chapter__ja,.pc-page.dark-theme .pc-empty__title{color:var(--text-primary)}.pc-page.dark-theme .pc-sub,.pc-page.dark-theme .pc-chapter__zh,.pc-page.dark-theme .pc-chapter__meta{color:var(--text-secondary)}
