@import "../../../../styles/secondary-page-shell.wxss";
@import "../../../../styles/tokens.wxss";
page{background:var(--qp-color-canvas);overflow-x:hidden}.jl-page{min-height:100vh;padding:28rpx;box-sizing:border-box;background:var(--qp-color-canvas);color:var(--qp-color-ink);overflow-x:hidden}.jl-page.dark-theme{background:var(--bg-color);color:var(--text-primary)}.jl-head{margin-bottom:24rpx}.jl-kicker{display:block;color:var(--qp-color-primary);font-size:22rpx;font-weight:700;margin-bottom:8rpx}.jl-title{display:block;color:var(--qp-color-ink);font-size:42rpx;line-height:1.25;font-weight:700}.jl-sub,.jl-source,.jl-copy,.jl-card-sub{display:block;color:var(--qp-color-text-secondary);font-size:25rpx;line-height:1.65}.jl-card{margin-bottom:18rpx;padding:20rpx;border-radius:8rpx;background:var(--qp-color-surface);border:var(--qp-border-width) solid var(--qp-color-line)}.jl-card--handson{border-left:6rpx solid var(--qp-color-primary)}.jl-card-title,.jl-empty-title{display:block;color:var(--qp-color-ink);font-size:29rpx;font-weight:700;line-height:1.35;margin-bottom:8rpx}.jl-copy--ja{color:var(--qp-color-ink)}.jl-term{padding:12rpx 0;border-top:var(--qp-border-width) solid var(--qp-color-line)}.jl-term:first-of-type{border-top:0}.jl-term__name{display:block;color:var(--qp-color-primary);font-size:25rpx;font-weight:700}.jl-code-head{display:flex;align-items:center;justify-content:space-between;gap:12rpx}.jl-copy-btn{flex:none;padding:8rpx 18rpx;border-radius:var(--qp-radius-tag);color:var(--qp-color-primary);border:var(--qp-border-width) solid var(--qp-color-line-strong);font-size:23rpx}.java-code-scroll{max-width:100%;overflow-x:auto;margin:12rpx 0;padding:16rpx;box-sizing:border-box;border-radius:8rpx;background:var(--qp-color-surface-muted);border:var(--qp-border-width) solid var(--qp-color-line)}.java-code{white-space:pre;font-family:var(--qp-font-family-data);font-size:23rpx;line-height:1.55;color:var(--qp-color-ink)}.java-output{display:block;white-space:pre-wrap;padding:14rpx;margin:8rpx 0 12rpx;border-radius:8rpx;background:var(--qp-color-primary-soft);color:var(--qp-color-ink);font-family:var(--qp-font-family-data);font-size:23rpx;line-height:1.45}.jl-btn{margin-top:16rpx;min-height:72rpx;display:flex;align-items:center;justify-content:center;border-radius:8rpx;color:var(--qp-color-surface);background:var(--qp-color-primary);font-size:27rpx;font-weight:700}.jl-page.dark-theme .jl-card{background:var(--card-bg);border-color:var(--border-color)}.jl-page.dark-theme .jl-title,.jl-page.dark-theme .jl-card-title,.jl-page.dark-theme .jl-empty-title,.jl-page.dark-theme .jl-copy--ja,.jl-page.dark-theme .java-code,.jl-page.dark-theme .java-output{color:var(--text-primary)}.jl-page.dark-theme .jl-sub,.jl-page.dark-theme .jl-source,.jl-page.dark-theme .jl-copy,.jl-page.dark-theme .jl-card-sub{color:var(--text-secondary)}
