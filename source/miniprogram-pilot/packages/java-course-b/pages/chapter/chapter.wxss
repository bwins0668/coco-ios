@import "../../../../styles/secondary-page-shell.wxss";
@import "../../../../styles/tokens.wxss";
page{background:var(--qp-color-canvas);overflow-x:hidden}.jc-page{min-height:100vh;padding:28rpx;box-sizing:border-box;background:var(--qp-color-canvas);color:var(--qp-color-ink);overflow-x:hidden}.jc-page.dark-theme{background:var(--bg-color);color:var(--text-primary)}.jc-hero,.jc-section,.jc-empty{background:var(--qp-color-surface);border:var(--qp-border-width) solid var(--qp-color-line);border-radius:var(--qp-radius-sm)}.jc-hero{padding:28rpx;margin-bottom:24rpx;border-top:5rpx solid var(--qp-color-primary)}.jc-kicker{display:block;color:var(--qp-color-primary);font-size:22rpx;font-weight:700;margin-bottom:8rpx}.jc-title{display:block;color:var(--qp-color-ink);font-size:42rpx;line-height:1.25;font-weight:700}.jc-sub,.jc-empty__sub,.jc-chapter__zh,.jc-chapter__meta{display:block;color:var(--qp-color-text-secondary);font-size:25rpx;line-height:1.6}.jc-stats{display:flex;gap:12rpx;margin:24rpx 0}.jc-stat{flex:1;padding:16rpx;border-radius:var(--qp-radius-tag);background:var(--qp-color-primary-soft)}.jc-stat__num{display:block;color:var(--qp-color-primary);font-size:34rpx;font-weight:700}.jc-stat__label{display:block;color:var(--qp-color-text-secondary);font-size:22rpx}.jc-btn{min-height:76rpx;display:flex;align-items:center;justify-content:center;border-radius:var(--qp-radius-tag);font-size:27rpx;font-weight:700}.jc-btn--primary{background:var(--qp-color-primary);color:var(--qp-color-surface)}.jc-btn--outline{border:var(--qp-border-width) solid var(--qp-color-line-strong);color:var(--qp-color-primary)}.jc-section{padding:20rpx;margin-bottom:20rpx}.jc-section__title{display:block;color:var(--qp-color-primary);font-size:24rpx;font-weight:700;margin-bottom:14rpx}.jc-chapter{display:flex;gap:16rpx;align-items:center;padding:18rpx 0;border-top:var(--qp-border-width) solid var(--qp-color-line)}.jc-chapter:first-of-type{border-top:0}.jc-chapter__body{flex:1;min-width:0}.jc-chapter__ja{display:block;color:var(--qp-color-ink);font-size:29rpx;line-height:1.35;font-weight:700}.jc-chapter__arrow{flex:none;color:var(--qp-color-primary);font-size:32rpx}.jc-empty{padding:44rpx 24rpx}.jc-empty__title{display:block;font-size:34rpx;font-weight:700;margin-bottom:8rpx}.jc-page.dark-theme .jc-hero,.jc-page.dark-theme .jc-section,.jc-page.dark-theme .jc-empty{background:var(--card-bg);border-color:var(--border-color)}.jc-page.dark-theme .jc-title,.jc-page.dark-theme .jc-chapter__ja,.jc-page.dark-theme .jc-empty__title{color:var(--text-primary)}.jc-page.dark-theme .jc-sub,.jc-page.dark-theme .jc-chapter__zh,.jc-page.dark-theme .jc-chapter__meta{color:var(--text-secondary)}
