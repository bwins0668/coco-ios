<view class="jc-page {{__themeDark ? 'dark-theme' : ''}} secondary-shell" style="padding-top: {{navSafeTop}}px;"><view class="secondary-nav secondary-nav--back-only"><view class="secondary-nav__back" bindtap="goBack" data-secondary-route="packages/java-course/pages/chapter/chapter"><text class="secondary-nav__back-icon">‹</text></view></view><block wx:if="{{loadError}}"><view class="jc-empty"><text class="jc-empty__title">章节暂不可用</text><text class="jc-empty__sub">找不到这个 Java 章节，可能是链接参数不完整。</text><view class="jc-btn jc-btn--outline" bindtap="goBack">返回 Java 课程</view></view></block><block wx:else><view class="jc-hero"><text class="jc-kicker">Chapter {{chapter.chapterOrder}}</text><text class="jc-title">{{chapter.title.ja}}</text><text class="jc-sub">{{chapter.title.zh}}</text><view class="jc-stats"><view class="jc-stat"><text class="jc-stat__num">{{lessons.length}}</text><text class="jc-stat__label">小节</text></view><view class="jc-stat"><text class="jc-stat__num">{{chapter.pageStart}}-{{chapter.pageEnd}}</text><text class="jc-stat__label">教材页</text></view></view></view><view class="jc-section"><text class="jc-section__title">小节列表</text><view class="jc-chapter" wx:for="{{lessons}}" wx:key="lessonId" bindtap="openLesson" data-lesson-id="{{item.lessonId}}"><view class="jc-chapter__body"><text class="jc-chapter__ja">{{item.title.ja}}</text><text class="jc-chapter__zh">{{item.title.zh}}</text><text class="jc-chapter__meta">第 {{item.order}} 节 · PDF {{item.sourceRef.pageStart}} 页</text></view><text class="jc-chapter__arrow">→</text></view></view></block></view>
