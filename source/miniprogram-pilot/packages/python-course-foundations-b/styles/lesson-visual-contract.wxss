/* Shard-local lesson visual contract (mirrored from legacy, non-import rules only) */
page{background:#FBF7EF;overflow-x:hidden}.pl-page{--python-khaki-accent:#9A7B48;--python-khaki-strong:#765A2B;--python-khaki-soft:#F4EBD8;--python-khaki-border:#D8C39A;--python-khaki-ink:#4A3B25;min-height:100vh;padding:28rpx;box-sizing:border-box;background:#FBF7EF;color:var(--python-khaki-ink);overflow-x:hidden}.pl-page.dark-theme{background:var(--bg-color);color:var(--text-primary)}.pl-head{margin-bottom:24rpx}.pl-kicker{display:block;color:var(--python-khaki-accent);font-size:22rpx;font-weight:700;margin-bottom:8rpx}.pl-title{display:block;color:var(--python-khaki-ink);font-size:42rpx;line-height:1.25;font-weight:700}.pl-sub,.pl-copy,.pl-card-sub{display:block;color:#6E6250;font-size:25rpx;line-height:1.65}.pl-card{margin-bottom:18rpx;padding:20rpx;border-radius:8rpx;background:#FFFDF8;border:var(--qp-border-width) solid var(--python-khaki-border)}.pl-card--handson{border-left:6rpx solid var(--python-khaki-accent)}.pl-card-title,.pl-empty-title{display:block;color:var(--python-khaki-ink);font-size:29rpx;font-weight:700;line-height:1.35;margin-bottom:8rpx}.pl-copy--ja{color:var(--python-khaki-ink)}.pl-term{padding:12rpx 0;border-top:var(--qp-border-width) solid var(--python-khaki-border)}.pl-term:first-of-type{border-top:0}.pl-term__name{display:block;color:var(--python-khaki-strong);font-size:25rpx;font-weight:700}.pl-code-head{display:flex;align-items:center;justify-content:space-between;gap:12rpx}.pl-copy-btn{flex:none;padding:8rpx 18rpx;border-radius:var(--qp-radius-tag);color:var(--python-khaki-strong);border:var(--qp-border-width) solid var(--python-khaki-border);font-size:23rpx}.python-code-scroll{max-width:100%;overflow-x:auto;margin:12rpx 0;padding:16rpx;box-sizing:border-box;border-radius:8rpx;background:var(--qp-color-surface-muted);border:var(--qp-border-width) solid var(--python-khaki-border)}.python-code{white-space:pre;font-family:var(--qp-font-family-data);font-size:23rpx;line-height:1.55;color:var(--python-khaki-ink)}.python-output{display:block;white-space:pre-wrap;padding:14rpx;margin:8rpx 0 12rpx;border-radius:8rpx;background:var(--python-khaki-soft);color:var(--python-khaki-ink);font-family:var(--qp-font-family-data);font-size:23rpx;line-height:1.45}.pl-btn{margin-top:16rpx;min-height:72rpx;display:flex;align-items:center;justify-content:center;border-radius:8rpx;color:#FFFDF8;background:var(--python-khaki-accent);font-size:27rpx;font-weight:700}.pl-page.dark-theme .pl-card{background:var(--card-bg);border-color:var(--border-color)}.pl-page.dark-theme .pl-title,.pl-page.dark-theme .pl-card-title,.pl-page.dark-theme .pl-empty-title,.pl-page.dark-theme .pl-copy--ja,.pl-page.dark-theme .python-code,.pl-page.dark-theme .python-output{color:var(--text-primary)}.pl-page.dark-theme .pl-sub,.pl-page.dark-theme .pl-copy,.pl-page.dark-theme .pl-card-sub{color:var(--text-secondary)}