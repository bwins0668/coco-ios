# Hermes 飞书凭据 (.env 文件示例)
# 用法:
#   cp data/feishu.env.example %LocalAppData%\hermes\feishu.env
#   把 cli_xxx 和 secret 改成实际值

# 飞书开放平台 → Hermes 应用 → 凭证与基础信息
LARK_APP_ID=cli_your_app_id_here
LARK_APP_SECRET=your_app_secret_here

# 事件与回调 → Verification Token
LARK_VERIFY_TOKEN=hermes-default-verify

# 加密 key（默认空）
LARK_ENCRYPT_KEY=

# 本机 webhook port
LARK_PORT=9876
